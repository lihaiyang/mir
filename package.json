{
  "name": "mir",
  "version": "0.1.25",
  "description": "Multi-pane IDE for AI agent management",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "typecheck": "vue-tsc --noEmit",
    "rebuild": "electron-rebuild -f -w node-pty",
    "pack": "npm run build && electron-builder --mac --arm64",
    "pack:dmg": "npm run build && electron-builder --mac --arm64 --publish=never",
    "pack:win": "npm run build && electron-builder --win --x64 --publish=never",
    "pack:linux": "npm run build && electron-builder --linux",
    "dev:quiet": "nohup env -u ELECTRON_RUN_AS_NODE electron-vite dev > /dev/null 2>&1 &"
  },
  "keywords": [],
  "author": {
    "name": "MIR",
    "email": "mir@example.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lihaiyang/mir.git"
  },
  "homepage": "https://github.com/lihaiyang/mir",
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.10"
  },
  "dependencies": {
    "@vueuse/core": "^12.8.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^8.2.0",
    "ignore": "^7.0.5",
    "monaco-editor": "^0.55.0",
    "node-pty": "^1.1.0",
    "path-browserify": "^1.0.1",
    "pinia": "^2.3.1",
    "simple-git": "^3.30.0",
    "uuid": "^11.1.0",
    "vue": "^3.5.16",
    "vue-i18n": "^9.14.4"
  },
  "build": {
    "appId": "com.mir.ide",
    "productName": "MIR",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": false,
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Development",
      "icon": "build/icon.icns",
      "executableArgs": [
        "--no-sandbox"
      ],
      "extraResources": []
    },
    "npmRebuild": false,
    "electronDownload": {
      "cache": ".electron-cache"
    },
    "afterPack": "scripts/linux-after-pack.js"
  }
}
